# ==========================================
# Java & Spring Boot Backend (STS/Maven)
# ==========================================
 
# Compiled files - will be regenerated by Maven
*.class
*.jar
*.war
*.ear
target/
build/
 
# Maven wrapper - not needed, Maven will handle dependencies
.mvn/
mvnw
mvnw.cmd
 
# IDE files - STS/Eclipse will regenerate these
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
bin/
 
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
 
# ==========================================
# React Frontend (VS Code)
# ==========================================
 
# Dependencies - will be installed by npm install
node_modules/
 
# Production build - will be created by npm run build
/build
/dist
 
# Environment files (if you have any)
.env.local
.env.development.local
.env.test.local
.env.production.local
 
# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
 
# Testing
/coverage
 
# ==========================================
# Database Files (Local Development)
# ==========================================
 
# Only ignore local database files, not configuration
*.db
*.sqlite
*.sqlite3
*.h2.db
*.mv.db
*.trace.db
 
# ==========================================
# Operating System Files
# ==========================================
 
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
 
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
 
# Linux
*~
.directory
 
# ==========================================
# Logs & Temporary Files
# ==========================================
 
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
 
# ==========================================
# VS Code
# ==========================================
.vscode/
*.code-workspace
 